# Copy this file to ".env" and fill in your key.  cp .env.example .env
#
# Get a free key at https://openrouter.ai/keys — no credit card needed for the free tier.
# Keep this key secret. Never commit your real .env file (it's gitignored).

OPENROUTER_API_KEY=

# Optional: your Gousto session cookie for accessing your personal weekly menu.
# Leave blank to scrape the public catalogue (~200 recipes).
# To obtain: log in at gousto.co.uk, open DevTools → Application → Cookies → copy the value of "gousto_session".
GOUSTO_SESSION_COOKIE=
